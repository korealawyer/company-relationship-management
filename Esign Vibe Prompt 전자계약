### 3. Supabase 연결 시 DB 스키마 (미리 설계)

```sql
CREATE TABLE contracts (
  id              uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  tenant_id       uuid NOT NULL,              -- RLS 격리 키 (⚠️ law_firm_id 사용 금지)
  contract_initiated_by text CHECK (contract_initiated_by IN ('law_firm', 'client')),
  client_company_id text,                     -- DocComment company_id와 동일 타입: 'corp-1' | 'corp-2' | 'corp-3'
                                              -- ⚠️ uuid REFERENCES companies(id) 아님 — TEXT로 통일
  template_type   text,
  counterparty_name text,
  counterparty_email text,
  status          text DEFAULT 'pending' CHECK (status IN ('pending','sent','viewed','signed','completed','expired')),
  token           uuid DEFAULT gen_random_uuid() UNIQUE,  -- 서명 링크 토큰
  pdf_storage_path text,                       -- private bucket 경로 (signed URL 1시간 만료)
  linked_document_id uuid REFERENCES documents(id),  -- 서명 완료 후 DocComment documents 테이블과 역방향 연결
  created_at      timestamptz DEFAULT now(),
  expires_at      timestamptz
);

-- RLS
ALTER TABLE contracts ENABLE ROW LEVEL SECURITY;
CREATE POLICY tenant_isolation ON contracts
  USING (tenant_id = (auth.jwt() ->> 'tenant_id')::uuid);
```

