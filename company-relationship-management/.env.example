# ── IBS CRM 환경변수 (.env.local에 복사하여 사용) ──────────────

# Supabase (Phase 2에서 활성화)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 이메일 발송 (Nodemailer)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# OpenAI API (AI 초안 생성용)
OPENAI_API_KEY=

# 사이트 URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000
