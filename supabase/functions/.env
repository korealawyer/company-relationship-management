# Supabase Edge Function 환경변수
# 위치: supabase/functions/.env (로컬 개발용)
# 배포 시: supabase secrets set KEY=VALUE --env-file .env.supabase

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ── 카카오 알림톡 ─────────────────────────────────────────────────────────────
# 심사 완료 전 → EMAIL_FALLBACK=true 설정으로 이메일 대체 발송
KAKAO_ALIMTALK_API_KEY=MOCK_NOT_YET_ISSUED
KAKAO_CHANNEL_ID=MOCK_NOT_YET_ISSUED
EMAIL_FALLBACK=true

# ── 이메일 (Resend) ───────────────────────────────────────────────────────────
# 기존 RESEND_API_KEY 사용
RESEND_API_KEY=YOUR_RESEND_API_KEY_HERE
FROM_EMAIL=noreply@YOUR_DOMAIN.com

# ── SMS 폴백 (NCP) ────────────────────────────────────────────────────────────
# 카카오 연동 후 활성화 예정
NCP_SMS_ACCESS_KEY=
NCP_SMS_SECRET_KEY=
NCP_SMS_SERVICE_ID=
NCP_SMS_SENDER=
