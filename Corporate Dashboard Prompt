## 🔑 DB 스키마 (더미 데이터로 구현, 추후 Supabase 연결)

```typescript
// 법인 기본 정보
interface CorporateClient {
  id: string;
  name: string;                    // "(주)교촌에프앤비"
  tier: 'A' | 'B' | 'C';
  retainerPlan: 'Starter' | 'Standard' | 'Premium' | 'Enterprise';
  industry: string;
  employeeCount: number;
  annualRevenueRange: string;
  assignedLawyer: string;
  legalContact: { name: string; title: string; email: string };
  retainerStartDate: string;
  retainerEndDate: string;
  riskScore: number;               // 0~10
}

// 계약
interface Contract {
  id: string;
  corporateId: string;
  name: string;
  counterparty: string;
  type: '공급계약' | '임대차' | '용역계약' | '라이선스' | '기타';
  expiresAt: string;
  autoRenew: boolean;
  status: '활성' | '갱신협의' | '만료' | '해지';
}

// 이사
interface Director {
  id: string;
  corporateId: string;
  name: string;
  title: string;                   // "대표이사" | "사내이사" | "감사"
  termExpiresAt: string;
  registrationStatus: '등기완료' | '변경필요' | '미등기';
}

// 사건
interface Case {
  id: string;
  corporateId: string;
  title: string;
  type: '민사' | '형사' | '행정' | '노동' | '지식재산';
  riskLevel: 'High' | 'Medium' | 'Low';
  assignedLawyer: string;
  nextHearingDate?: string;
  status: '진행중' | '완료' | '항소';
}
```

